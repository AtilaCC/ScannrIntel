# ============================================================
# ScannrIntel — .env.example (CORRIGIDO E COMPLETO)
# Principal Engineer Review — junho 2026
#
# COMO USAR:
#   cp .env.example .env
#   Preencha TODOS os campos marcados com <PREENCHER>
#   NUNCA commite o .env real no git
#
# GERADOR DE SECRETS:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================

# ── JWT ────────────────────────────────────────────────────
# OBRIGATÓRIO: mínimo 48 caracteres aleatórios
# CRÍTICO: JWT_ACCESS_SECRET e JWT_REFRESH_SECRET DEVEM ser diferentes
JWT_ACCESS_SECRET=<PREENCHER_min_48_chars_aleatorios>
JWT_REFRESH_SECRET=<PREENCHER_min_48_chars_aleatorios_DIFERENTE_DO_ANTERIOR>
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Banco de Dados ─────────────────────────────────────────
# OBRIGATÓRIO: nunca usar valores simples como "crypto_pass" em produção
POSTGRES_USER=<PREENCHER_ex_scannr_prod>
POSTGRES_PASSWORD=<PREENCHER_senha_forte_min_32_chars>
POSTGRES_DB=crypto_intelligence

# ── Redis ──────────────────────────────────────────────────
REDIS_PASSWORD=<PREENCHER_senha_forte_min_32_chars>
REDIS_MAX_MEMORY=256mb

# ── APIs de IA ────────────────────────────────────────────
# Groq (modelo llama3/mixtral — gratuito com rate limits)
GROQ_API_KEY=<PREENCHER_gsk_...>
# Anthropic (opcional, para upgrade para Claude)
# ANTHROPIC_API_KEY=<PREENCHER_sk-ant-...>

# ── APIs Externas (Opcionais) ──────────────────────────────
CRYPTOPANIC_API_KEY=<OPCIONAL>
WHALE_ALERT_API_KEY=<OPCIONAL>

# ── CORS ───────────────────────────────────────────────────
# OBRIGATÓRIO: domínio real em produção, nunca wildcard (*)
# Desenvolvimento:
CORS_ORIGIN=http://localhost:3000
# Produção (exemplo Railway):
# CORS_ORIGIN=https://seu-frontend.railway.app

# ── URLs Públicas do Frontend ─────────────────────────────
# IMPORTANTE: Next.js embute NEXT_PUBLIC_* em BUILD TIME
# Trocar aqui requer rebuild da imagem Docker do frontend
# Desenvolvimento:
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000/ws
# Produção (exemplo Railway):
# NEXT_PUBLIC_API_URL=https://seu-backend.railway.app
# NEXT_PUBLIC_WS_URL=wss://seu-backend.railway.app/ws

# ── Configurações de Portas (opcional) ────────────────────
HTTP_PORT=80
HTTPS_PORT=443

# ── Configurações de Aplicação ────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
BCRYPT_ROUNDS=12

# ── Scanner ────────────────────────────────────────────────
SCAN_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,LINKUSDT,UNIUSDT,ATOMUSDT,LTCUSDT,ETCUSDT,XLMUSDT,TRXUSDT,NEARUSDT,DOGEUSDT,APTUSDT,ARBUSDT,OPUSDT

# ── AI Service ─────────────────────────────────────────────
AI_WORKER_COUNT=3
AI_RATE_LIMIT_RPM=50

# ── Versão da App (para tags Docker) ──────────────────────
APP_VERSION=1.0.0

# ── SEGURANÇA: CHECKLIST ANTES DE FAZER DEPLOY ────────────
# [ ] JWT_ACCESS_SECRET tem mínimo 48 chars aleatórios?
# [ ] JWT_REFRESH_SECRET é DIFERENTE do ACCESS_SECRET?
# [ ] POSTGRES_PASSWORD é forte (min 32 chars, sem palavras comuns)?
# [ ] REDIS_PASSWORD está definido?
# [ ] CORS_ORIGIN aponta para o domínio real (não localhost)?
# [ ] NEXT_PUBLIC_API_URL aponta para o backend de produção?
# [ ] Este arquivo .env NÃO está commitado no git?
# [ ] O .gitignore inclui .env e .env.local?
