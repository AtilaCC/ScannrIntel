# ============================================================
# CRYPTO INTELLIGENCE PLATFORM — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
DATABASE_URL=postgresql://crypto_user:crypto_pass@localhost:5432/crypto_intelligence

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://:redis_pass@localhost:6379

# ── JWT Secrets (CHANGE THESE! min 32 chars each) ────────────
JWT_ACCESS_SECRET=change_me_super_secret_access_key_min_32_chars_!!
JWT_REFRESH_SECRET=change_me_super_secret_refresh_key_min_32_chars_!!

# ── Backend ───────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
BCRYPT_ROUNDS=12
LOG_LEVEL=info

# ── Anthropic / Claude AI ─────────────────────────────────────
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Scanner ───────────────────────────────────────────────────
# Comma-separated Binance symbols to scan
SCAN_SYMBOLS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,AVAXUSDT,DOTUSDT,MATICUSDT,LINKUSDT,UNIUSDT,ATOMUSDT,LTCUSDT,ETCUSDT,XLMUSDT

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# ── Railway deployment (fill after Railway setup) ─────────────
# RAILWAY_TOKEN=...
# RAILWAY_PROJECT_ID=...
